# --- Server ---
SERVER_PORT=1001
SERVER_HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# --- JWT ---
JWT_SECRET=replace-with-a-random-32+-chars-secret
JWT_EXPIRES_IN=365d

# --- Auth (LDAP only) ---
AUTH_PROVIDER=ldap
# RSA key pair for encrypting login credentials (PEM, use \n for newlines in .env)
AUTH_RSA_PRIVATE_KEY=
AUTH_RSA_PUBLIC_KEY=
AUTH_COOKIE_NAME=porteria_access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_MAX_AGE=0
LDAP_URL=ldaps://ldap.example.com:636
LDAP_DOMAIN=example.com
LDAP_BASE_DN=DC=example,DC=com
LDAP_ADMIN=
LDAP_ADMIN_PWD=

# --- GLPI 9.4.2 ---
GLPI_BASE_URL=http://glpi.example.com/apirest.php
GLPI_APP_TOKEN=
GLPI_CATALOG_BOOTSTRAP_LOGIN=
GLPI_CATALOG_BOOTSTRAP_PASSWORD=
GLPI_DEFAULT_ENTITY=0
GLPI_REQUEST_TIMEOUT_MS=15000
GLPI_SESSION_TTL_SECONDS=28800
# false = cuenta API sin perfil técnico (recomendado). true = parche si GLPI sigue auto-asignando Portería.
GLPI_STRIP_SERVICE_ASSIGNMENT=false
# ID numérico del usuario de Portería en GLPI (ej. 1368). Opcional; solo si GLPI_STRIP_SERVICE_ASSIGNMENT=true.
GLPI_SERVICE_USER_ID=
GLPI_HISTORY_SOURCE=sql   # api | sql
GLPI_METRICS_SOURCE=sql   # api | sql
# Escritura del cambio de estado (botones de acción del historial). sql requiere MYSQL_USER con permiso UPDATE.
GLPI_STATUS_SOURCE=sql    # api | sql (sql = lectura/escritura rápida vía MySQL)
# Fuente de creación de tickets (sql recomendado; fallback automático a api si falla SQL).
GLPI_CREATE_SOURCE=sql    # api | sql
# Fuente de asignación de técnico (sql recomendado; fallback automático a api si falla SQL).
GLPI_ASSIGN_SOURCE=sql    # api | sql
# Fuente para listado de técnicos en /users/technicians (sql recomendado por performance).
GLPI_TECHNICIANS_SOURCE=sql  # api | sql
# Fuente para listado general de usuarios en /users (sql recomendado por performance).
GLPI_USERS_SOURCE=sql  # api | sql

# --- MySQL (historial e indicadores SQL) ---
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=soporte
MYSQL_USER=lectura
MYSQL_PASSWORD=''
MYSQL_CONNECTION_LIMIT=5
MYSQL_CONNECT_TIMEOUT_MS=5000

# --- PostgreSQL (BD propia Portería) ---
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DATABASE=porteria_back
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_CONNECTION_LIMIT=5
POSTGRES_CONNECT_TIMEOUT_MS=5000
POSTGRES_SSL=false

# --- Cache ---
CACHE_TTL_DEFAULT_SECONDS=600
CACHE_TTL_CATALOG_SECONDS=3600

# --- SMTP (opcional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_AUTH=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=Portería
SMTP_REJECT_UNAUTHORIZED=true
MAIL_SUPPORT_TO=
#MAIL_DEFAULT_CC=martin.schuf@grupopettengill.com.py

# POST /mail/send y GET /mail/categories (prueba manual, sin JWT). Desactivado por defecto.
# MAIL_TEST_ENDPOINT_ENABLED=true
# MAIL_SUPPORT_TO=soporte@empresa.com
# Técnico y tipo por defecto para crear ticket desde /mail/send.
# También fallback de auto-asignación cuando un usuario final crea ticket y no hay TI activo en su sede.
# Si MAIL_INBOUND_DEFAULT_TECHNICIAN_ID coincide con GLPI_SERVICE_USER_ID,
# conviene GLPI_STRIP_SERVICE_ASSIGNMENT=false para no quitar asignación intencional.
MAIL_INBOUND_DEFAULT_TECHNICIAN_ID=1368
MAIL_INBOUND_DEFAULT_TICKET_TYPE=request

# --- Attachments (almacenamiento propio: PostgreSQL + disco local) ---
# Ejecutar scripts/sql/ticket-attachments.sql en PostgreSQL antes de usar adjuntos.
ATTACHMENTS_STORAGE_PATH=./data/attachments
ATTACHMENTS_MAX_BYTES=52428800
ATTACHMENTS_ALLOWED_MIME=image/png,image/jpeg,image/webp,text/plain,text/markdown,text/x-markdown,application/pdf

# --- IA (scaffold, sin uso en MVP) ---
AI_PROVIDER=
OPENAI_API_KEY=
